# Copy this file to .env.local for local development
# NEVER commit .env.local to git — add it to .gitignore

# Your Anthropic API key
# Get it from: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-...

# Restrict which frontend URL can call this API (optional but recommended in production)
# Set to your deployed frontend URL, e.g. https://my-app.vercel.app
# Leave blank or set to * during development
ALLOWED_ORIGIN=*
