# Copy this file to .env.local for local development
# NEVER commit .env.local to git — it is already in .gitignore

# Your Gemini API key
# Get it from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Restrict which frontend URL can call this API (optional, recommended in production)
# Set to your deployed Vercel URL, e.g. https://glass-installer-app.vercel.app
# Leave as * during development
ALLOWED_ORIGIN=*
