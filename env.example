# Copy this file to .env.local for local development
# NEVER commit .env.local to git — it is in .gitignore

# Gemini API key — used by api/scan.js on the server
# Get it from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Optional: restrict which origin can call /api/scan
# Set to your Vercel URL in production, e.g. https://glass-installer-app.vercel.app
# Leave as * for development
ALLOWED_ORIGIN=*
